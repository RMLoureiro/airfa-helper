# ── Database ───────────────────────────────────────────────────────────────────
POSTGRES_USER=airfa
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=airfa

# ── Backend ────────────────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-a-random-64-char-hex-string

# Comma-separated list of allowed frontend origins (no trailing slash)
CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com

# ── Seed ───────────────────────────────────────────────────────────────────────
# Set RUN_SEED=true on FIRST deploy only to create the initial accounts and demo data.
# Set it back to false (or remove it) before restarting to avoid re-seeding.
RUN_SEED=false

# Super admin account credentials (applied when RUN_SEED=true)
SUPER_ADMIN_USERNAME=admin
SUPER_ADMIN_NAME=Administrador Principal
SEED_SUPER_ADMIN_PASSWORD=change-me-strong-admin-password

# Passwords for the demo admin/member accounts created by the seed
SEED_ADMIN_PASSWORD=change-me-admin-password
SEED_REGULAR_PASSWORD=change-me-member-password

# ── Frontend ───────────────────────────────────────────────────────────────────
# Public URL of the backend API as seen from the user's browser.
# NOTE: This is baked in at Docker build time (Next.js NEXT_PUBLIC_* variable).
#       Rebuild the frontend image if this value changes.
NEXT_PUBLIC_API_URL=https://api.your-domain.com
